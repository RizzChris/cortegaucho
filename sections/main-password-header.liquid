{%- style -%}
  /* --- Wrapper flotando sobre el banner, sin ocupar espacio propio --- */
  #shopify-section-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .color-{{ section.settings.color_scheme }} {
    background: transparent;
  }

  #shopify-section-{{ section.id }} .password-header {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 2rem 3rem;
  }

  /* --- Toggle: mostrar solo el link cuando está cerrado --- */
  #shopify-section-{{ section.id }} .password-modal {
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .modal__toggle-open {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    color: #f7f2ea;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .modal__toggle-open:hover {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .modal__toggle-open .svg-wrapper svg {
    width: 1rem;
    height: 1rem;
  }

  #shopify-section-{{ section.id }} .modal__toggle-close {
    display: none;
  }

  #shopify-section-{{ section.id }} .password-modal[open] .modal__toggle-open {
    display: none;
  }

  #shopify-section-{{ section.id }} .password-modal[open] .modal__toggle-close {
    display: flex;
  }

  /* --- El diálogo en sí: oculto por default, overlay fijo centrado cuando [open] --- */
  #shopify-section-{{ section.id }} .modal__content {
    display: none;
  }

  #shopify-section-{{ section.id }} .password-modal[open] .modal__content {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    inset: 0;
    background: rgba(15, 12, 10, 0.7);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    z-index: 100;
    padding: 1.5rem;
    animation: password-overlay-in 0.25s ease-out;
  }

  @keyframes password-overlay-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes password-box-in {
    from { opacity: 0; transform: translateY(10px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  #shopify-section-{{ section.id }} .password-modal__content {
    position: relative;
    background: #f7f2ea;
    color: #241d16;
    border-radius: 2px;
    border-top: 3px solid #a9793e;
    padding: 3rem 2.5rem 2.5rem;
    width: 100%;
    max-width: 400px;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.45);
    animation: password-box-in 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .modal__close-button {
    position: absolute;
    top: 1.1rem;
    right: 1.1rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #7a6f60;
    padding: 0.3rem;
    line-height: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .modal__close-button:hover {
    color: #241d16;
    transform: rotate(90deg);
  }

  #shopify-section-{{ section.id }} .modal__close-button svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  #shopify-section-{{ section.id }} .password-modal__content-heading {
    margin: 0 0 0.4rem;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  #shopify-section-{{ section.id }} .password-modal__content-heading::after {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: #a9793e;
    margin: 1rem auto 1.6rem;
  }

  #shopify-section-{{ section.id }} .password-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  #shopify-section-{{ section.id }} .password-field {
    text-align: left;
  }

  #shopify-section-{{ section.id }} .password-field .field__input {
    width: 100%;
    padding: 0.95rem 1.1rem;
    border: 1px solid #d9cfbf;
    border-radius: 2px;
    background: #fff;
    font-size: 0.95rem;
    color: #241d16;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  #shopify-section-{{ section.id }} .password-field .field__input:focus {
    outline: none;
    border-color: #a9793e;
    box-shadow: 0 0 0 3px rgba(169, 121, 62, 0.15);
  }

  #shopify-section-{{ section.id }} .password-field .field__input::placeholder {
    color: #9a8f7d;
  }

  #shopify-section-{{ section.id }} .password-field .field__label {
    display: none;
  }

  #shopify-section-{{ section.id }} .password-button {
    padding: 0.95rem 1rem;
    border-radius: 2px;
    background: #241d16;
    color: #f7f2ea;
    border: 1px solid #241d16;
    cursor: pointer;
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .password-button:hover {
    background: #a9793e;
    border-color: #a9793e;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .password__footer-text {
    display: block;
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: #8a7f6d;
  }

  #shopify-section-{{ section.id }} .password__footer-text a {
    color: #6b5636;
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .form__message {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
    font-size: 0.82rem;
    color: #b3413a;
  }

  #shopify-section-{{ section.id }} .form__message svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }}">
  <div class="password-header">
    <password-modal>
      <details class="password-modal modal">
        <summary class="modal__toggle" aria-haspopup="dialog">
          <div class="modal__toggle-open password-link link underlined-link">
            <span class="svg-wrapper">
              {{- 'icon-padlock.svg' | inline_asset_content -}}
            </span>
            {{ 'general.password_page.login_password_button' | t }}
          </div>
          <div class="modal__toggle-close" aria-hidden="true">
            <span class="svg-wrapper">
              {{- 'icon-close.svg' | inline_asset_content -}}
            </span>
          </div>
        </summary>
        <div
          class="modal__content"
          role="dialog"
          aria-labelledby="DialogHeading"
          aria-modal="true"
        >
          <div class="password-modal__content" tabindex="-1">
            <button type="button" class="modal__close-button link" aria-label="{{ 'accessibility.close' | t }}">
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
            <h2 class="password-modal__content-heading" id="DialogHeading">
              {{ 'general.password_page.login_form_heading' | t }}
            </h2>
            {%- form 'storefront_password', class: 'password-form' -%}
              <div class="password-field field{% if form.errors %} password-field--error{% endif %}">
                <input
                  type="password"
                  name="password"
                  id="Password"
                  class="field__input"
                  autocomplete="current-password"
                  {% if form.errors %}
                    aria-invalid="true"
                    aria-describedby="PasswordLoginForm-password-error"
                  {%- endif -%}
                  placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
                >
                <label class="field__label" for="{{ 'general.password_page.login_form_password_label' | t }}">
                  {{- 'general.password_page.login_form_password_placeholder' | t -}}
                </label>
                {%- if form.errors -%}
                  <div id="PasswordLoginForm-password-error" role="status">
                    <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                    <span class="form__message">
                      <span class="svg-wrapper">
                        {{- 'icon-error' | inline_asset_content -}}
                      </span>
                      {{ 'general.password_page.login_form_error' | t -}}
                    </span>
                  </div>
                {%- endif -%}
              </div>
              <button name="commit" class="password-button button button--outline">
                {{ 'general.password_page.login_form_submit' | t }}
              </button>
            {%- endform -%}
            <small class="password__footer-text">{{ 'general.password_page.admin_link_html' | t }}</small>
          </div>
        </div>
      </details>
    </password-modal>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-password-header.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
